# ─────────────────────────────────────────────────────────────
# Supabase — Proyecto Luz Torres
# Project Settings → API   (https://supabase.com/dashboard/project/acrzgrbovizhqcnpmpdn/settings/api)
# ─────────────────────────────────────────────────────────────

# URL del proyecto (público)
NEXT_PUBLIC_SUPABASE_URL=https://acrzgrbovizhqcnpmpdn.supabase.co

# Clave anónima / pública (segura para el navegador)
NEXT_PUBLIC_SUPABASE_ANON_KEY=PEGA_AQUI_LA_ANON_KEY

# Clave service_role — SECRETA, solo servidor. Nunca exponer al cliente.
# Se usa para crear el usuario admin e invitar a nuevos miembros del equipo.
SUPABASE_SERVICE_ROLE_KEY=PEGA_AQUI_LA_SERVICE_ROLE_KEY

# URL pública del sitio (para metadatos SEO y sitemap)
NEXT_PUBLIC_SITE_URL=https://luztorres.com
